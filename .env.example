# Supabase project credentials — from Project Settings > API in the Supabase dashboard.
# NEVER commit the real .env file, and never paste real values in chat.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Shared secret ElevenLabs sends in the X-Webhook-Secret header — same as the
# original Flask backend. Generate with: openssl rand -hex 24
WEBHOOK_SECRET=replace-me-with-a-long-random-string

# Optional overrides
# PORT=5001
# VERIFICATION_TTL_SECONDS=600
